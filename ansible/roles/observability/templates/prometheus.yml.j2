---
# Managed by Ansible.
global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: 30s
  external_labels:
    cluster: homelab
    host: "{{ inventory_hostname }}"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

rule_files:
  - /etc/prometheus/alert-rules.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  - job_name: traefik
    static_configs:
      - targets: ['traefik:8083']
    metrics_path: /metrics

  - job_name: loki
    static_configs:
      - targets: ['loki:3100']
    metrics_path: /metrics

  - job_name: tempo
    static_configs:
      - targets: ['tempo:3200']
    metrics_path: /metrics

  - job_name: alertmanager
    static_configs:
      - targets: ['alertmanager:9093']
    metrics_path: /metrics

{% if homeassistant_host | length > 0 %}
  - job_name: homeassistant
    scrape_interval: 60s
    metrics_path: {{ homeassistant_metrics_path }}
    scheme: http
    authorization:
      credentials: "{{ homeassistant_metrics_token }}"
    static_configs:
      - targets: ['{{ homeassistant_host }}']
{% endif %}
