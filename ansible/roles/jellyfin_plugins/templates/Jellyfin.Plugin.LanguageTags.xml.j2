<?xml version="1.0" encoding="utf-8"?>
<!--
  LanguageTags plugin configuration. Templated by Ansible — manual edits in
  Jellyfin Dashboard → Plugins → Language Tags will be overwritten on next
  deploy. Tags emitted use full English language names with the configured
  prefixes, e.g. `language_Czech` (audio) and `subtitle_language_Czech` (subs).
-->
<PluginConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <AlwaysForceFullRefresh>false</AlwaysForceFullRefresh>
  <WhitelistLanguageTags></WhitelistLanguageTags>
  <!-- Default upstream is false; enabled here so subtitle-only Czech media
       (Bazarr-downloaded .srt sidecars, internal MKV sub tracks) gets tagged. -->
  <AddSubtitleTags>true</AddSubtitleTags>
  <SynchronousRefresh>false</SynchronousRefresh>
  <DisableUndefinedLanguageTags>false</DisableUndefinedLanguageTags>
  <AudioLanguageTagPrefix>language_</AudioLanguageTagPrefix>
  <SubtitleLanguageTagPrefix>subtitle_language_</SubtitleLanguageTagPrefix>
  <EnableNonMediaTagging>false</EnableNonMediaTagging>
  <NonMediaTag>item</NonMediaTag>
  <NonMediaItemTypes></NonMediaItemTypes>
  <TagSeriesOnly>false</TagSeriesOnly>
</PluginConfiguration>
