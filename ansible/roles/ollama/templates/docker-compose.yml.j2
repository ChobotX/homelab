---
# Ollama — local LLM inference.
# Backend-only on the `proxy` network — no Traefik router, no LAN/WAN ports.
# Other containers reach it via DNS name `ollama:11434`; Home Assistant (over
# WireGuard) via the wg0-bound published port below. Adding a UI (e.g.
# OpenWebUI) later means adding Traefik labels + wg-only@file gate then.
services:
  ollama:
    image: ${OLLAMA_IMAGE}
    container_name: ollama
    restart: unless-stopped
    # Model eviction + KV-cache flush want a moment before SIGKILL on stop.
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      OLLAMA_HOST: "0.0.0.0:11434"
      OLLAMA_KEEP_ALIVE: ${OLLAMA_KEEP_ALIVE}
{% if nvidia_gpu_enabled | default(false) | bool %}
      # Classic NVIDIA runtime mode — delegates GPU selection to
      # nvidia-container-runtime via these env vars. Simpler than the
      # `deploy.resources.reservations.devices` form, which needs CDI
      # devices generated by `nvidia-ctk cdi generate` (NV toolkit 1.17+
      # defaults to CDI). On this single-GPU host, give the container all
      # visible devices + the two capabilities ollama needs.
      NVIDIA_VISIBLE_DEVICES: all
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
{% endif %}
    volumes:
      - ${OLLAMA_MODELS_ROOT}:/root/.ollama
    ports:
      # HA voice pipeline (Ollama conversation agent on HAOS, 10.8.0.7) dials
      # this over WireGuard. Bound to the wg0 IP only — not LAN/WAN-exposed.
      - "{{ ollama_wg_bind_ip }}:11434:11434"
    networks:
      - proxy
{% if ollama_warmup_model %}
    # Preload {{ ollama_warmup_model }} on every container start so the first
    # HA voice command after a restart doesn't pay the cold model load: start
    # the server, wait for the API, load the model with an empty prompt, keep
    # serving. Guarded on the model already being on disk — a fresh host must
    # not trigger a multi-GiB pull at boot (the ansible pull task owns that).
    # trap forwards SIGTERM so graceful model eviction still happens on stop.
    entrypoint:
      - /bin/sh
      - -c
      - |
        /bin/ollama serve &
        pid=$$!
        trap 'kill -TERM "$$pid"; wait "$$pid"' TERM INT
        until /bin/ollama list >/dev/null 2>&1; do sleep 1; done
        if /bin/ollama list | grep -q '^{{ ollama_warmup_model }}'; then
          /bin/ollama run {{ ollama_warmup_model }} "" >/dev/null 2>&1 || true
        fi
        wait "$$pid"
{% endif %}
{% if nvidia_gpu_enabled | default(false) | bool %}
    # Pinning the nvidia runtime (registered by the nvidia_container role in
    # daemon.json) makes the NVIDIA env vars above active at start.
    runtime: nvidia
{% endif %}
    healthcheck:
      # /api/tags returns JSON listing loaded models — 200 means the HTTP
      # server is up even if no model is resident yet.
      test: ["CMD-SHELL", "ollama list >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s

networks:
  proxy:
    external: true
