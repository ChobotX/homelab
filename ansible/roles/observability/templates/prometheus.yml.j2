---
# Managed by Ansible.
global:
  scrape_interval: {{ observability_prometheus_scrape_interval }}
  evaluation_interval: 30s
  external_labels:
    cluster: homelab
    host: "{{ inventory_hostname }}"

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:9093']

rule_files:
  - /etc/prometheus/alert-rules.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  # Host node_exporter (systemd, not a compose service). Reached via
  # host-gateway — see `extra_hosts` on the prometheus compose service.
  - job_name: node
    static_configs:
      - targets: ['host.docker.internal:{{ observability_node_exporter_port }}']

  - job_name: traefik
    static_configs:
      - targets: ['traefik:8083']
    metrics_path: /metrics

  - job_name: loki
    static_configs:
      - targets: ['loki:3100']
    metrics_path: /metrics

  - job_name: tempo
    static_configs:
      - targets: ['tempo:3200']
    metrics_path: /metrics

  - job_name: alertmanager
    static_configs:
      - targets: ['alertmanager:9093']
    metrics_path: /metrics

{% if nvidia_gpu_enabled | default(false) | bool %}
  - job_name: nvidia_gpu
    # Exporter runs on the host (systemd, see observability role). Prometheus
    # reaches it via docker's host-gateway alias — requires `extra_hosts` on
    # the prometheus service (see docker-compose.yml).
    static_configs:
      - targets: ['host.docker.internal:{{ observability_nvidia_exporter_port }}']

{% endif %}
  - job_name: homeassistant
    scrape_interval: 60s
    metrics_path: {{ observability_homeassistant_metrics_path }}
    scheme: http
    authorization:
      credentials: "{{ homeassistant_metrics_token }}"
    static_configs:
      - targets: ['{{ homeassistant_host }}']

  # Alloy container on HAOS — exposes its own /metrics on the WG IP so this
  # homelab Prom can scrape it over WG. Alerts on `up{job=...}=0` flag
  # dead-tunnel / dead-Alloy / dead-HAOS in one shot.
  - job_name: homeassistant-alloy
    scrape_interval: 60s
    metrics_path: /metrics
    scheme: http
    static_configs:
      - targets: ['{{ observability_homeassistant_wg_ip }}:12345']

  # Blackbox exporter self-metrics (probe duration, errors, cert info). Probe
  # jobs below hit /probe via relabel; this one hits /metrics directly.
  - job_name: blackbox_exporter
    static_configs:
      - targets: ['blackbox_exporter:9115']
    metrics_path: /metrics

  # Push notification channel liveness. ntfy probed over HTTP (/v1/health),
  # the bridge over TCP (no GET-safe endpoint). Feeds the push_channel
  # alert group in alert-rules.yml, which routes firings to email via the
  # `channel: email` label.
  - job_name: blackbox_push_channel
    scrape_interval: 30s
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - "http://ntfy:80/v1/health"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox_exporter:9115

  - job_name: blackbox_push_channel_bridge
    scrape_interval: 30s
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
      - targets:
          - "ntfy_alertmanager:8080"
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox_exporter:9115
      - target_label: job
        replacement: blackbox_push_channel

{% if observability_uptime_http_targets %}
  # External HTTP uptime probes. Targets in group_vars/host defaults.
  - job_name: blackbox_http
    scrape_interval: 60s
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for t in observability_uptime_http_targets %}
          - "{{ t }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox_exporter:9115
{% endif %}

{% if observability_uptime_icmp_targets %}
  - job_name: blackbox_icmp
    scrape_interval: 60s
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
{% for t in observability_uptime_icmp_targets %}
          - "{{ t }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox_exporter:9115
{% endif %}
