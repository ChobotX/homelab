    {
      "type": "table",
      "title": "Containers",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": [
            "count"
          ],
          "countRows": true,
          "fields": "",
          "enablePagination": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Running"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "down",
                        "color": "red"
                      },
                      "1": {
                        "text": "up",
                        "color": "green"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Health"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "healthy": {
                        "color": "green"
                      },
                      "unhealthy": {
                        "color": "red"
                      },
                      "starting": {
                        "color": "yellow"
                      },
                      "none": {
                        "color": "text"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Restarts"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 3
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background-solid",
                  "mode": "gradient"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Memory"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_running",
          "format": "table",
          "instant": true,
          "refId": "Running"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "label_replace(sum by (name) (docker_container_health{status=\"healthy\"} == 1) * 0, \"Health\", \"healthy\", \"\", \"\") or label_replace(sum by (name) (docker_container_health{status=\"unhealthy\"} == 1) * 0, \"Health\", \"unhealthy\", \"\", \"\") or label_replace(sum by (name) (docker_container_health{status=\"starting\"} == 1) * 0, \"Health\", \"starting\", \"\", \"\") or label_replace(sum by (name) (docker_container_health{status=\"none\"} == 1) * 0, \"Health\", \"none\", \"\", \"\")",
          "format": "table",
          "instant": true,
          "refId": "Health"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "docker_container_restarts",
          "format": "table",
          "instant": true,
          "refId": "Restarts"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\"})",
          "format": "table",
          "instant": true,
          "refId": "Memory"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))",
          "format": "table",
          "instant": true,
          "refId": "CPU"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(name|Value.*|Health)$"
            }
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Container",
              "Value #Running": "Running",
              "Value #Restarts": "Restarts",
              "Value #Memory": "Memory",
              "Value #CPU": "CPU"
            },
            "indexByName": {
              "Container": 0,
              "Running": 1,
              "Health": 2,
              "Restarts": 3,
              "Memory": 4,
              "CPU": 5
            },
            "excludeByName": {}
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Container"
              }
            ]
          }
        }
      ]
    },
