[Unit]
Description=Daily btrfs snapshot timer

[Timer]
# 02:00 — runs BEFORE restic at 03:00, so the next restic backup catches
# any intra-day changes plus the fresh snapshot point. Persistent=true
# fires on next boot if the timer was missed (laptop suspend equivalent
# for the homelab — host reboot during the 02:00 window).
OnCalendar={{ storage_btrfs_snapshot_oncalendar }}
RandomizedDelaySec=10min
Persistent=true

[Install]
WantedBy=timers.target
