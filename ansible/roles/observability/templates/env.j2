GRAFANA_IMAGE={{ observability_grafana_image }}
PROMETHEUS_IMAGE={{ observability_prometheus_image }}
LOKI_IMAGE={{ observability_loki_image }}
TEMPO_IMAGE={{ observability_tempo_image }}
ALERTMANAGER_IMAGE={{ observability_alertmanager_image }}
ALLOY_IMAGE={{ observability_alloy_image }}

OBSERVABILITY_HOST={{ observability_host }}
ALERTMANAGER_HOST={{ observability_alertmanager_host }}
WG_IP={{ wireguard_address.split('/')[0] }}

PROMETHEUS_RETENTION={{ observability_prometheus_retention }}

GRAFANA_UID={{ observability_grafana_uid }}
GRAFANA_GID={{ observability_grafana_gid }}
PROMETHEUS_UID={{ observability_prometheus_uid }}
PROMETHEUS_GID={{ observability_prometheus_gid }}
LOKI_UID={{ observability_loki_uid }}
LOKI_GID={{ observability_loki_gid }}
TEMPO_UID={{ observability_tempo_uid }}
TEMPO_GID={{ observability_tempo_gid }}
ALERTMANAGER_UID={{ observability_alertmanager_uid }}
ALERTMANAGER_GID={{ observability_alertmanager_gid }}

GRAFANA_MEM_LIMIT={{ observability_grafana_mem_limit }}
PROMETHEUS_MEM_LIMIT={{ observability_prometheus_mem_limit }}
LOKI_MEM_LIMIT={{ observability_loki_mem_limit }}
TEMPO_MEM_LIMIT={{ observability_tempo_mem_limit }}
ALERTMANAGER_MEM_LIMIT={{ observability_alertmanager_mem_limit }}
ALLOY_MEM_LIMIT={{ observability_alloy_mem_limit }}

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
GF_SERVER_ROOT_URL=https://{{ observability_host }}
GF_SERVER_DOMAIN={{ observability_host }}
GF_AUTH_ANONYMOUS_ENABLED=false
GF_USERS_ALLOW_SIGN_UP=false
GF_USERS_VIEWERS_CAN_EDIT=false
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false
GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/var/lib/grafana/dashboards/homelab-overview.json
GF_UNIFIED_ALERTING_ENABLED=true
GF_UNIFIED_ALERTING_SCREENSHOTS_CAPTURE=false
GF_LOG_MODE=console
