---
# Managed by Ansible.
#
# Push-first notification model:
#   - Default route   → ntfy (via the ntfy-alertmanager bridge)
#   - `channel=email` → email (fallback receiver for meta-alerts that fire
#                       when the push path itself is unhealthy; see the
#                       push_channel group in alert-rules.yml)
#   - SMTP is kept wired up in globals because the email receiver still uses it.
global:
  resolve_timeout: 5m
  smtp_smarthost: "{{ alertmanager_smtp_host }}"
  smtp_from: "{{ alertmanager_smtp_from }}"
  smtp_auth_username: "{{ alertmanager_smtp_from }}"
  smtp_auth_password: "{{ alertmanager_smtp_password }}"
  smtp_require_tls: true

route:
  receiver: ntfy
  group_by: [alertname, severity]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  routes:
    # Meta-alerts about the push path itself. Matched first so they never
    # try to deliver over the very channel they're reporting as broken.
    - matchers:
        - channel = email
      receiver: email
      group_wait: 10s
      repeat_interval: 1h
    - matchers:
        - severity = critical
      receiver: ntfy
      group_wait: 10s
      repeat_interval: 1h

receivers:
  - name: ntfy
    webhook_configs:
      - url: http://ntfy_alertmanager:8080/
        send_resolved: true
        http_config:
          basic_auth:
            username: "{{ observability_ntfy_bridge_webhook_user }}"
            password: "{{ ntfy_bridge_webhook_password }}"

  - name: email
    email_configs:
      - to: "{{ alertmanager_email_to }}"
        send_resolved: true
        headers:
          Subject: "[homelab] {% raw %}{{ .Status | toUpper }}{% endraw %} — {% raw %}{{ .CommonLabels.alertname }}{% endraw %}"

inhibit_rules:
  - source_matchers: [severity = critical]
    target_matchers: [severity = warning]
    equal: [alertname, instance]
