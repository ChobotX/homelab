      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scrape_duration_seconds{job=\"homeassistant\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Sensors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Temperature",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hass_sensor_temperature_celsius",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Humidity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hass_sensor_humidity_percent",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Battery level",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "min"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hass_battery_level_percent",
          "legendFormat": "{{friendly_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Power (kWh)",
