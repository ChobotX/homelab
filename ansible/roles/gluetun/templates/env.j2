{# Managed by Ansible — mode 0600. Contains Mullvad WireGuard private key. #}
GLUETUN_IMAGE={{ gluetun_image }}
QBITTORRENT_HOST={{ qbittorrent_host }}
PROWLARR_HOST={{ prowlarr_host }}
QBITTORRENT_WEBUI_PORT={{ qbittorrent_webui_port }}
PROWLARR_WEBUI_PORT={{ prowlarr_webui_port }}

# Mullvad WireGuard profile. Both values come from Mullvad's WG config
# download page (https://mullvad.net/en/account/wireguard-config). Private
# key + assigned addresses are written to /etc/homelab/secrets/ by hand
# once; bootstrap never touches them.
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY={{ mullvad_wireguard_private_key }}
{# Mullvad's WG config bundles both an IPv4 and an IPv6 address. Host has v6
   disabled, so passing the v6 entry to gluetun fails: "interface address is
   IPv6 but IPv6 is not supported". Filter to v4-only — split on comma, drop
   any address containing ':' (v6 marker), rejoin. #}
WIREGUARD_ADDRESSES={{ mullvad_wireguard_addresses.split(',') | map('trim') | reject('search', ':') | join(',') }}
SERVER_CITIES={{ gluetun_server_cities }}

# Killswitch: FIREWALL=on blocks every egress path except the Mullvad tunnel.
# FIREWALL_OUTBOUND_SUBNETS whitelists ONLY the arr docker network — needed
# so Traefik (arr member) can reach gluetun's published UI ports and return
# traffic can reach the caller. NOT the host LAN. NOT 0.0.0.0/0. NOT proxy.
FIREWALL=on
FIREWALL_OUTBOUND_SUBNETS={{ docker_arr_network_subnet }}
BLOCK_IPV6={{ gluetun_block_ipv6 }}

# DNS-over-TLS through the tunnel. Shared-netns apps resolve via 127.0.0.1
# (gluetun's local DoT proxy) — no leak to host resolver.
DOT={{ gluetun_dot }}

# Healthcheck — tunnel up only if 1.1.1.1:443 is reachable via WG.
HEALTH_TARGET_ADDRESS={{ gluetun_health_target_address }}
HEALTH_VPN_DURATION_INITIAL={{ gluetun_health_vpn_duration_initial }}

TZ={{ homelab_timezone | default('Etc/UTC') }}
