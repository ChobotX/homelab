---
# Ollama — local LLM inference.
# On the `proxy` network — no host ports. In-cluster containers reach it via
# DNS name `ollama:11434`; external access (the pi orchestrator harness on the
# Mac, over WG) goes through Traefik at `{{ ollama_host }}`, gated wg-only@file.
services:
  ollama:
    image: ${OLLAMA_IMAGE}
    container_name: ollama
    restart: unless-stopped
    # Model eviction + KV-cache flush want a moment before SIGKILL on stop.
    stop_grace_period: 30s
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      OLLAMA_HOST: "0.0.0.0:11434"
      OLLAMA_KEEP_ALIVE: ${OLLAMA_KEEP_ALIVE}
{% if nvidia_gpu_enabled | default(false) | bool %}
      # Classic NVIDIA runtime mode — delegates GPU selection to
      # nvidia-container-runtime via these env vars. Simpler than the
      # `deploy.resources.reservations.devices` form, which needs CDI
      # devices generated by `nvidia-ctk cdi generate` (NV toolkit 1.17+
      # defaults to CDI). On this single-GPU host, give the container all
      # visible devices + the two capabilities ollama needs.
      NVIDIA_VISIBLE_DEVICES: all
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
{% endif %}
    volumes:
      - ${OLLAMA_MODELS_ROOT}:/root/.ollama
    networks:
      - proxy
{% if nvidia_gpu_enabled | default(false) | bool %}
    # Pinning the nvidia runtime (registered by the nvidia_container role in
    # daemon.json) makes the NVIDIA env vars above active at start.
    runtime: nvidia
{% endif %}
    healthcheck:
      # /api/tags returns JSON listing loaded models — 200 means the HTTP
      # server is up even if no model is resident yet.
      test: ["CMD-SHELL", "ollama list >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    labels:
      # Traefik-fronted so the pi orchestrator harness (Mac, over WG) can reach
      # the inference API — the homelab way: no host ports, wg-only@file gate.
      # WG is the moat; ollama has no auth of its own, so no dashboard-auth here.
      traefik.enable: "true"
      traefik.docker.network: "proxy"

      traefik.http.routers.ollama.rule: "Host(`{{ ollama_host }}`)"
      traefik.http.routers.ollama.entrypoints: "websecure"
      traefik.http.routers.ollama.tls: "true"
      traefik.http.routers.ollama.tls.certresolver: "cloudflare"
      traefik.http.routers.ollama.service: "ollama"
      traefik.http.routers.ollama.middlewares: "wg-only@file,security-headers@file"
      traefik.http.services.ollama.loadbalancer.server.port: "11434"

networks:
  proxy:
    external: true
