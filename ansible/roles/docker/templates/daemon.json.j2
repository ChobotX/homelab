{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  },
  "live-restore": true,
  "default-address-pools": [
    { "base": "10.200.0.0/16", "size": 24 }
  ],
  "no-new-privileges": true,
  "userland-proxy": false,
  "runtimes": {
{% if nvidia_gpu_enabled | default(false) | bool %}
    "nvidia": {
      "path": "nvidia-container-runtime",
      "runtimeArgs": []
    }
{% endif %}
  }
}
