#jinja2:lstrip_blocks: True
# Managed by Ansible — DO NOT EDIT MANUALLY.
# Private key is sourced from /etc/wireguard/privatekey (generated by bootstrap.sh).

[Interface]
Address = {{ wireguard_address }}
ListenPort = {{ wireguard_listen_port }}
MTU = {{ wireguard_mtu }}
PrivateKey = {{ (wireguard_privkey_content.content | b64decode).strip() }}

[Peer]
# {{ wireguard_peer_name }}
PublicKey = {{ wireguard_peer_hub_pubkey }}
{% if wireguard_psk_stat.stat.exists %}
PresharedKey = {{ (wireguard_psk_content.content | b64decode).strip() }}
{% endif %}
Endpoint = {{ wireguard_peer_hub_endpoint }}
AllowedIPs = {{ wireguard_peer_hub_allowedips }}
PersistentKeepalive = {{ wireguard_peer_keepalive }}
