    {
      "type": "timeseries",
      "title": "GPU temperature",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 49 },
      "id": 43,
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nvidia_smi_temperature_gpu",
          "legendFormat": "GPU",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Compute power (est.)",
      "description": "RAPL (CPU pkg + DRAM) + NVIDIA GPU draw, stacked. Undersells real PSU draw by ~30-50W baseline (mobo/fans/storage/PSU losses not visible to OS). Tracks load delta accurately.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 49 },
      "id": 44,
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_rapl_package_joules_total[5m]))",
          "legendFormat": "CPU pkg",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_rapl_dram_joules_total[5m]))",
          "legendFormat": "DRAM",
          "refId": "B"
        },
        {
