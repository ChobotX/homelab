# Managed by Ansible — mode 0600.
#
# This file is ONLY for docker-compose ${...} interpolation (image pin +
# Traefik host rule). It is deliberately NOT loaded into the container via
# env_file: the names below collide with reserved Trilium settings
# (TRILIUM_HOST = the listen host) and would crash the app if injected.
# The container's own config lives in the compose `environment:` block.
#
# First converge: the trilium role inits the DB (/api/setup/new-document),
# seeds the web-login password (/set-password) from
# /etc/homelab/secrets/trilium_password, then mints the ETAPI token via
# /etapi/auth/login and stores it at /etc/homelab/secrets/trilium_etapi_token.
TRILIUM_IMAGE={{ trilium_image }}
TRILIUM_HOST={{ trilium_host }}
