# Managed by Ansible — Hermes Agent config (mounted at /opt/data/config.yaml).
# Secrets are NOT here: ${...} refs resolve from /opt/data/.env (templated
# separately at mode 0600). Non-secret structured settings only.

model:
  default: "{{ hermes_model }}"
  provider: custom
  base_url: "{{ hermes_llm_base_url }}"
  api_key: "${HERMES_LLM_API_KEY}"

# Cross-session memory — self-hosted Honcho (honcho role, same docker net).
# Connection + identity live in honcho.json (seeded next to this file); the
# local baseUrl there makes the plugin skip API-key auth.
memory:
  provider: honcho

# Fully autonomous: NO approval prompts. This is acceptable ONLY because the
# container is the security boundary (no docker.sock, no host FS beyond
# /opt/data, scoped docker nets). The agent can do anything inside the
# container; it cannot escape to delete other services or touch the host.
approvals:
  mode: "off"

terminal:
  backend: local
  timeout: 180
  # Surface service endpoints + tokens to the agent's shell so it can curl
  # Loki / Prometheus / Home Assistant / Trilium. Hermes strips other
  # sensitive env from child processes by default.
  env_passthrough:
    - LOKI_URL
    - PROMETHEUS_URL
    - HOMEASSISTANT_URL
    - HOMEASSISTANT_TOKEN
    - TRILIUM_URL
    - TRILIUM_TOKEN

# Web: search via DDGS (DuckDuckGo, free, no key — `ddgs` vendored into
# /opt/data/pylib, PYTHONPATH in .env); extract via Tavily (cleaner full-page
# reads, key in .env). The hermes docker net has internet egress for both.
web:
  search_backend: ddgs
  extract_backend: tavily

# Iteration budget — runaway-loop circuit breaker for unattended operation.
agent:
  max_turns: {{ hermes_max_turns }}
  api_max_retries: {{ hermes_api_max_retries }}

discord:
  require_mention: true
  auto_thread: true
  reactions: true

# Home Assistant via its native MCP Server integration (SSE endpoint). The
# bearer reuses HOMEASSISTANT_TOKEN from .env (no duplicate secret); Hermes
# substitutes ${...} at config load. HA is reached over WG through host routing
# — the "Model Context Protocol Server" integration must be enabled HA-side.
mcp_servers:
  homeassistant:
    url: "{{ hermes_homeassistant_url }}/mcp_server/sse"
    # HA's MCP Server speaks the SSE protocol, not Streamable HTTP (the default)
    # — without this the probe POSTs and HA answers 405 Method Not Allowed.
    transport: sse
    headers:
      Authorization: "Bearer ${HOMEASSISTANT_TOKEN}"

# Hermes refuses to bind the dashboard on a non-loopback address without its
# own auth provider (the bind is 0.0.0.0 so Traefik can reach it across the
# hermes net). Basic-auth hash is minted once on-host and slurped; the
# plaintext lives in /etc/homelab/secrets/hermes_dashboard_password. WG-only
# at the Traefik edge remains the outer moat. The scrypt hash has no ${...}
# refs so Hermes' env substitution leaves it intact.
dashboard:
  basic_auth:
    username: "{{ hermes_dashboard_user }}"
    password_hash: "{{ hermes_dashboard_password_hash }}"
