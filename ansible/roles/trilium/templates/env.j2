# Managed by Ansible — mode 0600.
#
# First converge: the trilium role inits the DB (/api/setup/new-document),
# seeds the web-login password (/set-password) from
# /etc/homelab/secrets/trilium_password, then mints the ETAPI token via
# /etapi/auth/login and stores it at
# /etc/homelab/secrets/trilium_etapi_token. There is no password env var —
# Trilium has no headless password override, so it is set over HTTP once.
TRILIUM_IMAGE={{ trilium_image }}
TRILIUM_HOST={{ trilium_host }}
TRILIUM_DATA_DIR={{ trilium_data_dir }}

TRILIUM_GENERAL_INSTANCENAME={{ trilium_instance_name }}

TRILIUM_NETWORK_HOST=0.0.0.0
TRILIUM_NETWORK_PORT=8080
# Trust Traefik's X-Forwarded-* so secure cookies + redirects use https on
# the web login. Maps to config.ini [Network] trustedReverseProxy.
TRILIUM_NETWORK_TRUSTEDREVERSEPROXY=true
