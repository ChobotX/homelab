# Bootstrap config — sourced by `bootstrap.sh --env FILE`.
#
# Every variable below is REQUIRED and must be non-empty. Bootstrap is a dumb
# pipe from this file into /etc/homelab/; Ansible handles everything else
# (htpasswd hashing, ssh-keyscan, HA scrape wiring, Alertmanager receivers,
# random-secret generation).
#
# Copy this file to `bootstrap.env` at repo root (gitignored) and fill in.
# Ship it to the homelab via USB along with the two private-key files
# referenced below.
#
# Usage on the homelab console:
#   sudo mount /dev/sdb1 /mnt
#   sudo /opt/homelab/bootstrap.sh --env /mnt/bootstrap.env
#
# Pre-requisite: the homelab's WireGuard pubkey must already be a [Peer] on
# the hub BEFORE you run bootstrap. See docs/bootstrap.md.

# ────────────────────────────────────────────────────────────────────────────
# HOST-TRUTH
# ────────────────────────────────────────────────────────────────────────────

ADMIN_USER=chobotx
HOMELAB_DOMAIN=homelab.example.com
ACME_EMAIL=you@example.com

# Your laptop's SSH public key. One line. Contents of `~/.ssh/id_ed25519.pub`.
LAPTOP_PUBKEY='ssh-ed25519 AAAA...replace-with-your-pubkey... comment'

# ────────────────────────────────────────────────────────────────────────────
# WIREGUARD — homelab side
# ────────────────────────────────────────────────────────────────────────────

WG_ADDRESS=10.8.0.6/24
WG_SUBNET=10.8.0.0/24
WG_LISTEN_PORT=51820

# Path to a pre-generated WG private key on the USB stick.
# Generate on your Mac:
#   wg genkey | tee homelab_wg_privkey | wg pubkey > homelab_wg_pubkey
#   chmod 0400 homelab_wg_privkey
# Add the pubkey to the hub's [Peer] list BEFORE running bootstrap.
WG_PRIVATE_KEY_PATH=/mnt/homelab_wg_privkey

# ────────────────────────────────────────────────────────────────────────────
# WIREGUARD — hub side
# ────────────────────────────────────────────────────────────────────────────

# Hub's WG public key (from the hub: `sudo wg show wg0 public-key`).
WG_PEER_PUBKEY='HUB-PUBKEY='

# Hub's public endpoint — `curl ifconfig.me` on the hub + its ListenPort.
WG_PEER_ENDPOINT='1.2.3.4:51820'

# Subnets routed through the hub. Always include the WG subnet. Add any LANs
# on other peers that the homelab needs to reach (e.g. HA's LAN for metrics scrape).
WG_PEER_ALLOWED='10.8.0.0/24'

# ────────────────────────────────────────────────────────────────────────────
# TRAEFIK
# ────────────────────────────────────────────────────────────────────────────

# Cloudflare API token with Zone:DNS:Edit for your domain.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_DNS01_TOKEN=''

# Traefik dashboard basic auth — plaintext; Ansible bcrypt-hashes it.
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=''

# ────────────────────────────────────────────────────────────────────────────
# RESTIC BACKUP (SFTP only)
# ────────────────────────────────────────────────────────────────────────────

# SFTP restic repo URL, e.g.:
#   sftp:u578479@u578479.your-storagebox.de:restic
# NOTE: Hetzner Storage Box chroots SFTP into your home and rejects absolute
# paths — use a relative path (no leading `/` after the colon).
RESTIC_REPO_URL=''
RESTIC_SFTP_HOST=''
RESTIC_SFTP_USER=''

# Path to your existing SFTP private key on the USB stick (so your current
# pubkey on the storage provider keeps working). Ansible copies it to
# /root/.ssh/ on the homelab and ssh-keyscans the host on every deploy.
RESTIC_SFTP_PRIVATE_KEY_PATH=/mnt/storagebox_key

# ────────────────────────────────────────────────────────────────────────────
# GITHUB ACTIONS RUNNER (ephemeral JIT)
# ────────────────────────────────────────────────────────────────────────────

GITHUB_REPO='owner/homelab'

# Fine-grained PAT scoped to the repo above.
# Permissions required: Administration r/w, Actions r/w, Contents read.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=''

# ────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY
# ────────────────────────────────────────────────────────────────────────────

# Home Assistant host:port for Prometheus scrape (reachable over the tunnel).
HOMEASSISTANT_HOST=''
# HA long-lived access token: HA UI → Profile → Security → Long-Lived Access Tokens.
HOMEASSISTANT_METRICS_TOKEN=''

# SMTP relay for Alertmanager email alerts.
ALERTMANAGER_SMTP_HOST=''
ALERTMANAGER_SMTP_FROM=''
ALERTMANAGER_EMAIL_TO=''
ALERTMANAGER_SMTP_PASSWORD=''
