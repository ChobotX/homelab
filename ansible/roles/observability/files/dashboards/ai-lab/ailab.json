    {
      "type": "timeseries",
      "title": "Power draw",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 25 },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }
