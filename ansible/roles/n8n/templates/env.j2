# Managed by Ansible — mode 0600.
N8N_IMAGE={{ n8n_image }}
N8N_HOST={{ n8n_host }}
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}
N8N_PROTOCOL=https
WEBHOOK_URL=https://{{ n8n_host }}/
GENERIC_TIMEZONE={{ timezone }}
DB_TYPE=sqlite
# Disable phone-home telemetry + version ping — keeps traffic WG-only.
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
# Traefik terminates TLS — trust the XFP header so n8n builds correct URLs.
N8N_PROXY_HOPS=1
